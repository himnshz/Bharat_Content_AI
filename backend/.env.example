# API Configuration
PORT=8000
DEBUG=True

# ============================================
# AI SERVICES CONFIGURATION
# Configure ONE or MORE services - system will auto-select best available
# ============================================

# --------------------------------------------
# Google Gemini API (Recommended - Free Tier)
# --------------------------------------------
# Get your free API key from: https://makersuite.google.com/app/apikey
# Best for: Multilingual content, free tier available
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# AWS Bedrock (Enterprise-grade)
# --------------------------------------------
# Method 1: IAM Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Method 2: Bearer Token (Alternative)
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here

# Bedrock Configuration
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --------------------------------------------
# OpenAI (High Quality)
# --------------------------------------------
# Get API key from: https://platform.openai.com/api-keys
# Best for: High-quality content generation
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------
# Anthropic Claude (Excellent for Content)
# --------------------------------------------
# Get API key from: https://console.anthropic.com/
# Best for: Long-form content, analysis
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --------------------------------------------
# Cohere (Good for Generation)
# --------------------------------------------
# Get API key from: https://dashboard.cohere.com/api-keys
# Best for: Text generation, embeddings
# COHERE_API_KEY=your_cohere_api_key_here
# COHERE_MODEL=command-r-plus

# --------------------------------------------
# HuggingFace (Open Source Models)
# --------------------------------------------
# Get API key from: https://huggingface.co/settings/tokens
# Best for: Custom models, experimentation
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# --------------------------------------------
# Groq (Fast Inference)
# --------------------------------------------
# Get API key from: https://console.groq.com/
# Best for: Speed-critical applications
# GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# Together AI (Open Source)
# --------------------------------------------
# Get API key from: https://api.together.xyz/settings/api-keys
# Best for: Cost-effective solutions
# TOGETHER_API_KEY=your_together_api_key_here

# ============================================
# AWS SERVICES (Optional)
# ============================================

# AWS Translate
TRANSLATE_REGION=us-east-1

# AWS Transcribe
TRANSCRIBE_REGION=us-east-1

# AWS S3 for media storage
S3_BUCKET_NAME=bharat-content-ai-media
S3_REGION=us-east-1

# AWS Secrets Manager
SECRETS_MANAGER_REGION=us-east-1

# AWS EventBridge (for scheduling)
EVENTBRIDGE_REGION=us-east-1

# AWS CloudWatch (for logging)
CLOUDWATCH_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/aws/bharat-content-ai

# ============================================
# DATABASE CONFIGURATION
# ============================================

# For development (SQLite)
DATABASE_URL=sqlite:///./bharat_content_ai.db

# For production (AWS RDS PostgreSQL)
# DATABASE_URL=postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/bharat_content_ai

# ============================================
# SOCIAL MEDIA APIs (Future Integration)
# ============================================
TWITTER_API_KEY=
FACEBOOK_API_KEY=
INSTAGRAM_API_KEY=

# ============================================
# APPLICATION SETTINGS
# ============================================
SECRET_KEY=your-secret-key-for-jwt-tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
