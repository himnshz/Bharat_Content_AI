# Environment Configuration
ENVIRONMENT=development  # development, staging, production

# Security
SECRET_KEY=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-KEY-IN-PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=sqlite:///./bharat_content_ai.db
# For PostgreSQL: postgresql://username:password@localhost:5432/dbname

# Redis (optional - for bulk operations and rate limiting)
REDIS_URL=redis://localhost:6379/0

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# OR use bearer token
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Optional AI Services (uncomment to enable)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# COHERE_API_KEY=your_cohere_key
# HUGGINGFACE_API_KEY=your_huggingface_key
# GROQ_API_KEY=your_groq_key
# TOGETHER_API_KEY=your_together_key

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=INFO
